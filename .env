# =============================================================================
# .env  ―  LFS rootfs ビルダー 設定ファイル
# compose.yml および lfs.sh から参照されます
# =============================================================================

COMPOSE_PROJECT_NAME=lfs_builder
CONTAINER_NAME=Docker_LFS

Dockerfile_DIR=.
Dockerfile=Dockerfile

ENTRY_DIR=Programs
ENTRY_POINT=lfs.sh

VOLUME=./build
WS=build

# ─────────────────────────────────────────────
# LFS バージョン・アーキテクチャ
# ─────────────────────────────────────────────
LFS_VERSION=12.2
LFS_ARCH=x86_64
LFS_TGT=x86_64-lfs-linux-gnu

# ─────────────────────────────────────────────
# LFS ソースミラー (wget-list / md5sums 取得先)
#
# 推奨: 以下のどれかをコメント解除して使用
#
# [1] 公式サイト（基本はこれ）
LFS_MIRROR=https://www.linuxfromscratch.org/lfs/downloads
#
# [2] SourceForge ミラー（公式が落ちているとき）
# LFS_MIRROR=https://downloads.sourceforge.net/project/linuxfromscratch/lfs/12.2
#
# [3] OSUOSL ミラー（Oregon State University、高速）
# LFS_MIRROR=https://ftp.osuosl.org/pub/lfs/lfs-packages/12.2
#
# ─────────────────────────────────────────────
# GNU パッケージミラー (mpfr / gmp / mpc など)
#
# ftp.gnu.org は低速・不安定なため ftpmirror.gnu.org を推奨
# GNU公式ミラーリスト: https://www.gnu.org/prep/ftp.en.html
#
# [1] GNU 自動選択ミラー（推奨）
GNU_MIRROR=https://ftpmirror.gnu.org
#
# [2] GNU 本家（遅い場合は上記に切り替え）
# GNU_MIRROR=https://ftp.gnu.org/gnu
#
# [3] JAIST ミラー（日本・高速）
# GNU_MIRROR=https://ftp.jaist.ac.jp/pub/GNU
#
# [4] IIJ ミラー（日本）
# GNU_MIRROR=https://ftp.iij.ad.jp/pub/gnu
#
# ─────────────────────────────────────────────
# GCC 依存ライブラリミラー (mpfr / gmp / mpc の代替取得元)
# GCC Pass1/2 ビルド時に sources/ から取得できない場合のフォールバック
#
# [1] GCC infrastructure（安定）
GCC_INFRA_MIRROR=https://gcc.gnu.org/pub/gcc/infrastructure
#
# ─────────────────────────────────────────────

# ─────────────────────────────────────────────
# ビルド並列数 (CPU コア数に合わせて調整)
# ─────────────────────────────────────────────
CPU_CORE=4

# ─────────────────────────────────────────────
# ロケール・タイムゾーン
# ─────────────────────────────────────────────
TIME_ZONE=Asia/Tokyo
LOCALE="ja_JP.UTF-8 UTF-8"
LANG="ja_JP.UTF-8"

# ─────────────────────────────────────────────
# rootfs 内 root パスワード
# ─────────────────────────────────────────────
ROOT_PASSWORD="password"
