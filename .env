# =============================================================================
# .env  ―  LFS rootfs ビルダー 設定ファイル
# compose.yml および lfs.sh から参照されます
# =============================================================================

COMPOSE_PROJECT_NAME=lfs_builder
CONTAINER_NAME=Docker_LFS

Dockerfile_DIR=.
Dockerfile=Dockerfile

ENTRY_DIR=Programs
ENTRY_POINT=lfs.sh

VOLUME=./build
WS=build

# ─────────────────────────────────────────────
# LFS バージョン・アーキテクチャ
# ─────────────────────────────────────────────
LFS_VERSION=12.2
LFS_ARCH=x86_64
LFS_TGT=x86_64-lfs-linux-gnu

# ─────────────────────────────────────────────
# ソースミラー
#
# 推奨: 以下のどれかをコメント解除して使用
#
# [1] 公式サイト（基本はこれ）
LFS_MIRROR=https://www.linuxfromscratch.org/lfs/downloads
#
# [2] SourceForge ミラー（公式が落ちているとき）
# LFS_MIRROR=https://downloads.sourceforge.net/project/linuxfromscratch/lfs/12.2
#
# [3] OSUOSL ミラー（Oregon State University、高速）
# LFS_MIRROR=https://ftp.osuosl.org/pub/lfs/lfs-packages/12.2
#
# ─────────────────────────────────────────────

# ─────────────────────────────────────────────
# ビルド並列数 (CPU コア数に合わせて調整)
# ─────────────────────────────────────────────
CPU_CORE=4

# ─────────────────────────────────────────────
# ロケール・タイムゾーン
# ─────────────────────────────────────────────
TIME_ZONE=Asia/Tokyo
LOCALE="ja_JP.UTF-8 UTF-8"
LANG="ja_JP.UTF-8"

# ─────────────────────────────────────────────
# rootfs 内 root パスワード
# ─────────────────────────────────────────────
ROOT_PASSWORD="password"
