# =============================================================================
# .env  ―  LFS rootfs ビルダー 設定ファイル
# compose.yml および lfs.sh から参照されます
# =============================================================================

COMPOSE_PROJECT_NAME=blfs_builder
CONTAINER_NAME=Docker_BLFS

Dockerfile_DIR=.
Dockerfile=Dockerfile

ENTRY_DIR=Programs
ENTRY_POINT=lfs.sh

VOLUME=./build
WS=build

# ─────────────────────────────────────────────
# LFS バージョン・アーキテクチャ
# ─────────────────────────────────────────────
LFS_VERSION=12.2
LFS_ARCH=x86_64
LFS_TGT=x86_64-lfs-linux-gnu

# ─────────────────────────────────────────────
# ソースミラー (LFS公式 or お好みのミラー)
# ─────────────────────────────────────────────
LFS_MIRROR=https://www.linuxfromscratch.org/lfs/downloads

# ─────────────────────────────────────────────
# ビルド並列数 (CPU コア数に合わせて調整)
# ─────────────────────────────────────────────
CPU_CORE=4

# ─────────────────────────────────────────────
# ロケール・タイムゾーン
# ─────────────────────────────────────────────
TIME_ZONE=Asia/Tokyo
LOCALE="ja_JP.UTF-8 UTF-8"
LANG="ja_JP.UTF-8"

# ─────────────────────────────────────────────
# rootfs 内 root パスワード
# ─────────────────────────────────────────────
ROOT_PASSWORD="password"
BLFS_MIRROR=https://www.linuxfromscratch.org/blfs/downloads
