# =============================================================================
# .env  ―  LFS rootfs ビルダー 設定ファイル
# compose.yml および lfs.sh から参照されます
# =============================================================================

COMPOSE_PROJECT_NAME=lfs_builder
CONTAINER_NAME=Docker_LFS

Dockerfile_DIR=.
Dockerfile=Dockerfile

ENTRY_DIR=Programs
ENTRY_POINT=lfs.sh

VOLUME=./build
WS=build

# ─────────────────────────────────────────────
# LFS バージョン・アーキテクチャ
# ─────────────────────────────────────────────
LFS_VERSION=12.2
LFS_ARCH=x86_64
LFS_TGT=x86_64-lfs-linux-gnu

# =============================================================================
# ミラー設定
# 各変数はスペース区切りで複数指定可能。左から順に試してフォールバックします。
# =============================================================================

# ── LFS ソースミラー (wget-list / md5sums / パッケージ一括取得) ──────────────
# wget-list に記載された全パッケージをここから取得します。
# 左から順に試します。全て失敗した場合は個別ミラーにフォールバックします。
#
# 利用可能なミラー:
#   https://www.linuxfromscratch.org/lfs/downloads        公式（基本）
#   https://ftp.osuosl.org/pub/lfs/lfs-packages/12.2     OSUOSL（高速）
#   https://mirror.pseudoform.org/lfs/12.2               pseudoform
#   https://ftp.lfs-matrix.net/pub/lfs/lfs-packages/12.2 lfs-matrix
LFS_MIRRORS=https://ftp.osuosl.org/pub/lfs/lfs-packages/12.2 https://www.linuxfromscratch.org/lfs/downloads https://ftp.lfs-matrix.net/pub/lfs/lfs-packages/12.2

# ── GNU パッケージミラー (mpfr / gmp / mpc / binutils / gcc など) ───────────
# ftp.gnu.org は低速・不安定。ftpmirror.gnu.org は自動的に近いミラーを選択します。
# GNU公式ミラーリスト: https://www.gnu.org/prep/ftp.en.html
#
# 利用可能なミラー（日本）:
#   https://ftpmirror.gnu.org            GNU自動選択（推奨）
#   https://ftp.jaist.ac.jp/pub/GNU      JAIST（石川）
#   https://ftp.iij.ad.jp/pub/gnu        IIJ
#   https://ftp.gnu.org/gnu              GNU本家（低速）
GNU_MIRRORS=https://ftpmirror.gnu.org https://ftp.jaist.ac.jp/pub/GNU https://ftp.iij.ad.jp/pub/gnu https://mirrors.kernel.org/gnu https://ftp.gnu.org/gnu

# ── GCC infrastructure ミラー (mpfr / gmp / mpc の確実な取得元) ─────────────
# GNU ミラーで取得できない場合のフォールバック
GCC_INFRA_MIRRORS=https://gcc.gnu.org/pub/gcc/infrastructure

# =============================================================================
# CLI パッケージ個別URLミラー設定（Step5）
# 各変数はスペース区切りで複数URL指定可能。左から順に試してフォールバックします。
# 未設定の場合は lfs.sh 内のデフォルト値（複数ミラー済み）が使われます。
# =============================================================================
#
# 例: ネットワーク制限がある環境でミラーを差し替える場合
#   CLI_URL_GIT=https://your-mirror.example.com/git-2.47.2.tar.xz https://fallback.example.com/git-2.47.2.tar.xz
#
# CLI_URL_SUDO=https://www.sudo.ws/dist/sudo-1.9.15p5.tar.gz
# CLI_URL_NANO=https://www.nano-editor.org/dist/v8/nano-8.3.tar.xz
# CLI_URL_CURL=https://curl.se/download/curl-8.11.1.tar.xz https://github.com/curl/curl/releases/download/curl-8_11_1/curl-8.11.1.tar.xz
# CLI_URL_PCRE2=https://github.com/PCRE2Project/pcre2/releases/download/pcre2-10.44/pcre2-10.44.tar.bz2
# CLI_URL_GIT=https://www.kernel.org/pub/software/scm/git/git-2.47.2.tar.xz https://mirrors.edge.kernel.org/pub/software/scm/git/git-2.47.2.tar.xz
# CLI_URL_HTOP=https://github.com/htop-dev/htop/releases/download/3.3.0/htop-3.3.0.tar.xz
# CLI_URL_LIBEVENT=https://github.com/libevent/libevent/releases/download/release-2.1.12-stable/libevent-2.1.12-stable.tar.gz
# CLI_URL_TMUX=https://github.com/tmux/tmux/releases/download/3.5a/tmux-3.5a.tar.gz
# CLI_URL_TREE=https://mama.indstate.edu/users/ice/tree/src/tree-2.1.3.tgz
# CLI_URL_BASH_COMPLETION=https://github.com/scop/bash-completion/releases/download/2.14.0/bash-completion-2.14.0.tar.xz
# CLI_URL_DBUS=https://dbus.freedesktop.org/releases/dbus/dbus-1.15.8.tar.xz
# CLI_URL_IPROUTE2=https://www.kernel.org/pub/linux/utils/net/iproute2/iproute2-6.12.0.tar.xz https://mirrors.edge.kernel.org/pub/linux/utils/net/iproute2/iproute2-6.12.0.tar.xz
# CLI_URL_DHCPCD=https://github.com/NetworkConfiguration/dhcpcd/releases/download/v10.0.10/dhcpcd-10.0.10.tar.xz
# CLI_URL_OPENSSH=https://cdn.openbsd.org/pub/OpenBSD/OpenSSH/portable/openssh-9.9p1.tar.gz https://ftp.openbsd.org/pub/OpenBSD/OpenSSH/portable/openssh-9.9p1.tar.gz
# CLI_URL_LIBGPG_ERROR=https://www.gnupg.org/ftp/gcrypt/libgpg-error/libgpg-error-1.50.tar.bz2 https://mirrors.dotsrc.org/gcrypt/libgpg-error/libgpg-error-1.50.tar.bz2
# CLI_URL_LIBGCRYPT=https://www.gnupg.org/ftp/gcrypt/libgcrypt/libgcrypt-1.11.0.tar.bz2 https://mirrors.dotsrc.org/gcrypt/libgcrypt/libgcrypt-1.11.0.tar.bz2
CLI_URL_GROFF=https://mirrors.kernel.org/gnu/groff/groff-1.23.0.tar.gz https://ftpmirror.gnu.org/groff/groff-1.23.0.tar.gz https://ftp.gnu.org/gnu/groff/groff-1.23.0.tar.gz
CLI_URL_GRUB=https://ftpmirror.gnu.org/grub/grub-2.12.tar.xz https://ftp.jaist.ac.jp/pub/GNU/grub/grub-2.12.tar.xz https://mirrors.kernel.org/gnu/grub/grub-2.12.tar.xz https://ftp.gnu.org/gnu/grub/grub-2.12.tar.xz
# grub-mkfont に必要な依存ライブラリ（未設定時は lfs.sh 内のデフォルトURLを使用）
# CLI_URL_LIBPNG=https://downloads.sourceforge.net/libpng/libpng-1.6.44.tar.xz https://github.com/pnggroup/libpng/releases/download/v1.6.44/libpng-1.6.44.tar.xz
# CLI_URL_FREETYPE=https://downloads.sourceforge.net/freetype/freetype-2.13.3.tar.xz https://download.savannah.gnu.org/releases/freetype/freetype-2.13.3.tar.xz
CLI_URL_UNIFONT=https://ftp.gnu.org/gnu/unifont/unifont-15.1.04/unifont_all-15.1.04.bdf.gz https://unifoundry.com/pub/unifont/unifont-15.1.04/font-builds/unifont_all-15.1.04.bdf.gz https://ftpmirror.gnu.org/unifont/unifont-15.1.04/unifont_all-15.1.04.bdf.gz https://mirrors.kernel.org/gnu/unifont/unifont-15.1.04/unifont_all-15.1.04.bdf.gz
CLI_URL_EXPAT=https://github.com/libexpat/libexpat/releases/download/R_2_6_2/expat-2.6.2.tar.xz
# CLI_URL_LIBPIPELINE=https://download.savannah.gnu.org/releases/libpipeline/libpipeline-1.5.0.tar.gz

# ── ダウンロードリトライ設定 ─────────────────────────────────────────────────
# 各ミラーに対するリトライ回数（ミラー切り替えとは別）
DL_RETRIES=5
# タイムアウト秒数（1ファイルあたり）
DL_TIMEOUT=90

# ─────────────────────────────────────────────
# ビルド並列数 (CPU コア数に合わせて調整)
# ─────────────────────────────────────────────
CPU_CORE=4

# ─────────────────────────────────────────────
# ロケール・タイムゾーン
# ─────────────────────────────────────────────
TIME_ZONE=Asia/Tokyo
LOCALE="ja_JP.UTF-8 UTF-8"
LANG="ja_JP.UTF-8"

# ─────────────────────────────────────────────
# rootfs 内 root パスワード
# ─────────────────────────────────────────────
ROOT_PASSWORD="password"
